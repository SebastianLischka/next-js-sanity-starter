# SANITY_STUDIO_PREVIEW_URL: Frontend URL used for Studio preview links and Presentation tool.
SANITY_STUDIO_PREVIEW_URL=http://localhost:3000
# SANITY_STUDIO_API_VERSION: Sanity API version date (YYYY-MM-DD) used by the Studio client.
SANITY_STUDIO_API_VERSION=2026-03-23
# SANITY_STUDIO_PROJECT_ID: Sanity project ID used by Studio.
SANITY_STUDIO_PROJECT_ID=replace-me-project-id
# SANITY_STUDIO_DATASET: Sanity dataset name used by Studio.
SANITY_STUDIO_DATASET=production
# SANITY_STUDIO_DEFAULT_LANGUAGE: Required default locale code for content and i18n fallbacks.
SANITY_STUDIO_DEFAULT_LANGUAGE=de
# SANITY_STUDIO_DEFAULT_LANGUAGE_TITLE: Human-readable label for the default language.
SANITY_STUDIO_DEFAULT_LANGUAGE_TITLE=Deutsch
# SANITY_STUDIO_I18N_ENABLED: Studio i18n switch; set to false to disable translation features/structure grouping.
SANITY_STUDIO_I18N_ENABLED=true
# SANITY_STUDIO_HOSTNAME: Optional Studio hostname for deploy commands.