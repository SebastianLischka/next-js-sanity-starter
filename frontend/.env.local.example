# NEXT_PUBLIC_SITE_URL: Public base URL of the frontend (used for sitemap, robots, canonical URLs).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_STUDIO_URL: URL of Sanity Studio used for preview links and Draft Mode integration.
NEXT_PUBLIC_STUDIO_URL=http://localhost:3333
# NEXT_PUBLIC_SITE_ENV: Public runtime environment label used by metadata/robots logic.
NEXT_PUBLIC_SITE_ENV=development

# RESEND_API_KEY: API key for Resend email delivery (contact/newsletter submissions).
RESEND_API_KEY=replace-me-resend-key
# NEXT_RESEND_TO_EMAIL: Inbox address that receives form submissions.
NEXT_RESEND_TO_EMAIL=replace-me@example.com
# NEXT_RESEND_FROM_EMAIL: Verified sender address used for outgoing emails.
NEXT_RESEND_FROM_EMAIL=replace-me@example.com

# NEXT_PUBLIC_DRFLEX_ENABLED: Enables DrFlex integration in the frontend.
NEXT_PUBLIC_DRFLEX_ENABLED=true
# NEXT_PUBLIC_DRFLEX_MEDICAL_PRACTICE_ID: DrFlex practice identifier used by the integration.
NEXT_PUBLIC_DRFLEX_MEDICAL_PRACTICE_ID=48540
# NEXT_PUBLIC_VERCEL_SPEED_INSIGHTS_ENABLED: Enables Vercel Speed Insights script.
NEXT_PUBLIC_VERCEL_SPEED_INSIGHTS_ENABLED=false
# NEXT_PUBLIC_I18N_DEFAULT_LOCALE: Default locale used when no locale can be resolved.
NEXT_PUBLIC_I18N_DEFAULT_LOCALE=de
# NEXT_PUBLIC_I18N_ENABLED: Frontend i18n switch; set to false to disable localized routing/switcher.
NEXT_PUBLIC_I18N_ENABLED=false

# NEXT_PUBLIC_SANITY_API_VERSION: Sanity API version date (YYYY-MM-DD) used by frontend queries.
NEXT_PUBLIC_SANITY_API_VERSION=2026-03-23
# NEXT_PUBLIC_SANITY_PROJECT_ID: Sanity project ID used by the frontend client.
NEXT_PUBLIC_SANITY_PROJECT_ID=replace-me-project-id
# NEXT_PUBLIC_SANITY_DATASET: Sanity dataset name used by the frontend client.
NEXT_PUBLIC_SANITY_DATASET=development
# SANITY_API_READ_TOKEN: Server-side read token for protected Sanity queries.
SANITY_API_READ_TOKEN=replace-me-sanity-read-token
# SANITY_REVALIDATE_SECRET: Shared secret used by Sanity webhook to trigger Next.js on-demand revalidation.
SANITY_REVALIDATE_SECRET=replace-me-revalidate-secret